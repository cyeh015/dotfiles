" important
se nocp

" searching
se incsearch
se ignorecase

" display
se scrolloff=5
se number
se ruler
se cmdheight=2
se cursorline
highlight Cursorline cterm=NONE ctermbg=black ctermfg=NONE

syntax on

" editing
se tabstop=4
se softtabstop=4
se shiftwidth=4
se expandtab
se autoindent
se smartindent

